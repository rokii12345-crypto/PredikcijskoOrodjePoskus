# Copy this file to .env.local and fill in real values.
# Do not commit .env.local to GitHub.

# Random secret used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Optional. If unset, the app stores data in a local SQLite file at
# data/gradnjaplan.db (fine for local dev and for self-hosting with a
# persistent disk). Set these two to point at a Turso database instead
# (required for Vercel, which has no persistent disk) - see DEPLOYMENT.md.
DATABASE_URL=
DATABASE_AUTH_TOKEN=
